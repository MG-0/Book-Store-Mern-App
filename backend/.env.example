# ============================================================
# BookStore Backend - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Fill in your own values
# 3. NEVER commit the ".env" file to Git — it is already in .gitignore
# ============================================================

# Server port
PORT=5000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret key — use a long, random string (e.g. generate with: openssl rand -base64 64)
JWT_KEY=your_super_secret_jwt_key_here
